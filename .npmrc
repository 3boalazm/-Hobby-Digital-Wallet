# lucide-react@0.344.0 (an existing TREK dependency, used throughout the app's
# icons — not something added in this work) declares a peer range of
# ^16.5.1 || ^17.0.0 || ^18.0.0, which doesn't include React 19. The root
# package.json's `overrides` pins React 19.2.6 across the workspace anyway,
# since lucide-react works fine in practice on React 19 — its peerDependencies
# range just hasn't caught up. Without this, npm's ERESOLVE check hard-fails
# on that gap instead of only warning about it.
legacy-peer-deps=true
